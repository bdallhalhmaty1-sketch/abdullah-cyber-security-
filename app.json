{
  "expo": {
    "name": "عبدالله الحماطي - الأمن السيبراني",
    "slug": "cyber-shield",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cyber-shield",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050503",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050503"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.alhammati.cybershield",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#050503"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
